doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title 404 - User Not Found
    style.
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        .container {
            text-align: center;
            background: #ffffff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            max-width: 400px;
            width: 90%;
        }

        h1 {
            font-size: 72px;
            color: #764ba2;
            margin-bottom: 10px;
        }

        h2 {
            font-size: 24px;
            color: #333;
            margin-bottom: 15px;
        }

        p {
            color: #666;
            margin-bottom: 25px;
        }

        a {
            display: inline-block;
            padding: 10px 20px;
            text-decoration: none;
            background: #764ba2;
            color: #fff;
            border-radius: 6px;
            transition: 0.3s ease;
        }

        a:hover {
            background: #5a3785;
        }

    body
        div(class="container")
            h1 404
            h2 User Not Found
            p Sorry, the user you are looking for does not exist or may have been removed.
            a(href="/") Go Back Home
